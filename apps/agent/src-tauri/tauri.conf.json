{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mini Activity Analytics Agent",
  "version": "1.0.0",
  "identifier": "com.mini.analytics.agent",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "beforeBuildCommand": "pnpm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Mini Activity Analytics Agent",
        "width": 980,
        "height": 860,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
